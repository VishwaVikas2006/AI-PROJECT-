# ============================================================================
# AI Learning Coach — environment template
# Copy to `.env` for local dev, or set these in the Vercel / Render dashboards
# for production. NO REAL SECRETS belong in this file.
# ============================================================================

# ---------- Backend (Render) ----------
# Render sets PORT automatically; keep this as a fallback for local runs.
PORT=5000

# MongoDB Atlas connection string (production). For local dev you may use
# mongodb://localhost:27017/ai-learning-coach
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/ai-learning-coach

# Auth signing secret — generate a long random string for production
JWT_SECRET=replace_with_a_long_random_string

# Frontend origin(s) allowed by CORS. Set to the Vercel URL in production,
# e.g. https://ai-learning-coach.vercel.app
CLIENT_URL=http://localhost:5173

# ---------- AI Providers ----------
# At least one provider API key must be set. Gemini is the default and primary.
# Additional providers are used as automatic fallbacks when Gemini is unavailable.

# Google Gemini (PRIMARY — required for default operation)
# Get your key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.0-flash
GEMINI_FAST_MODEL=gemini-2.0-flash
# Optional: set to true to log raw model content + metadata (off by default)
# GEMINI_DEBUG=false

# OpenRouter (FALLBACK #1 — optional)
# Sign up at https://openrouter.ai and create an API key.
# Enables DeepSeek, Qwen, Llama, Mistral models as fallback.
# OPENROUTER_API_KEY=your_openrouter_api_key

# Cohere (FALLBACK #2 — optional)
# Sign up at https://dashboard.cohere.com and create an API key.
# Uses command-r-plus by default.
COHERE_API_KEY=your_cohere_api_key
# COHERE_MODEL=command-r-plus

# Mistral AI (FALLBACK #3 — optional)
# Sign up at https://console.mistral.ai and create an API key.
# Uses mistral-small-latest by default.
# MISTRAL_API_KEY=
# MISTRAL_MODEL=mistral-small-latest

# Optional: enable verbose AI manager logging (shows provider, model, latency)
# AI_DEBUG=false

# ---------- Frontend (Vercel) ----------
# Absolute URL of the deployed backend (no trailing slash). Used by the API
# client to call the backend in production. In local dev this is omitted and
# the Vite proxy forwards /api to localhost:5000.
VITE_API_URL=https://ai-learning-coach-api.onrender.com
